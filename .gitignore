# =============================================================================
# Visual Studio / MSBuild
# =============================================================================
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# =============================================================================
# C++ build artifacts
# =============================================================================
# Our project-local build dir (vcxproj OutDir/IntDir target it explicitly).
build/
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
Win32/
ARM64/

# Compiler / linker leftovers
*.obj
*.pch
*.ipch
*.ipdb
*.iobj
*.pdb
*.idb
*.ilk
*.exp
*.map
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
*.aps

# Unit test EXE built by tests/build_tests.ps1 — output goes next to
# the IME DLL so g_hInst-resolved dict paths work, the source / script
# under tests/ is tracked but the EXE itself is a build artifact.
tests/test_runner.exe

# Resource-compiler intermediates
*.res

# Workaround files we create when the linker can't overwrite a loaded DLL.
*.locked.*

# =============================================================================
# .NET / C# build artifacts
# =============================================================================
# bin / obj already covered above. Add NuGet caches just in case.
packages/
*.nuget.props
*.nuget.targets

# Test / coverage output
TestResults/
*.coverage
*.coveragexml

# =============================================================================
# Editor / OS junk
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*.swp
*.bak
*.tmp
*~

# =============================================================================
# Third-party dictionaries that are too big to track
# =============================================================================
# UniDic-Lite is ~250 MB. Fetch via `pip install unidic-lite` and copy the
# DICDIR contents into third_party/mecab/unidic-lite/. See README.
third_party/mecab/unidic-lite/

# Installer payload zip is a build artifact produced by build_installer.ps1
# (~50 MB compressed). csproj picks it up via <EmbeddedResource> when
# present; a bare `dotnet build` from a fresh clone still succeeds because
# the include is conditional on Exists().
src/GenerativeIME.Installer/Embedded/

# =============================================================================
# Secrets (defensive — none expected in this repo today, but cheap to add)
# =============================================================================
*.env
*.env.local
secrets.json
appsettings.*.local.json

# =============================================================================
# Claude Code loop-engineering runtime state
# =============================================================================
# scripts/loop/run_e2e_loop.ps1 が書き出す状態 JSON とログ。CLAUDE.md /
# .claude/agents/ / .claude/settings.example.json は commit する。
.claude/state/
.claude/settings.local.json
