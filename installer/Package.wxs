<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!-- ProductVersion is normally injected by CI (build_msi.ps1 -Version →
       wix -d ProductVersion=x.y.z); the fallback below keeps local
       `wix build` / build_msi.ps1 runs working without one. -->
  <?ifndef ProductVersion ?>
    <?define ProductVersion = "0.2.2" ?>
  <?endif?>
  <Package Name="GenerativeIME" Manufacturer="GenerativeIME"
           Version="$(var.ProductVersion)" UpgradeCode="{C7E9A1B4-3D2F-4E6A-9C8B-1F0E2D3C4B5A}"
           Scope="perMachine" Compressed="yes">

    <SummaryInformation Description="GenerativeIME TSF Input Method" Manufacturer="GenerativeIME" />
    <!-- AllowSameVersionUpgrades: a same-version rebuild (developer hotfix
         or a CI re-release with the same version tag) reinstalls in place
         instead of hitting "already installed". Also makes WIX_UPGRADE_DETECTED
         fire on same-version reinstall, so the wipe / kill-app / stop-ctfmon
         custom actions below apply to that path too. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of GenerativeIME is already installed."
                  AllowSameVersionUpgrades="yes"
                  Schedule="afterInstallInitialize" />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="GenerativeIME" />
    </StandardDirectory>

    <Feature Id="Main" Title="GenerativeIME" Level="1">
      <ComponentGroupRef Id="PayloadFiles" />
      <ComponentGroupRef Id="TsfActivationRegistry" />
    </Feature>

    <!-- Register / unregister the TSF text service via regsvr32 (DllRegisterServer).
         Type 34 deferred custom action: the resolved Directory (INSTALLFOLDER) becomes
         the working directory, regsvr32.exe is found on PATH (System32), and the DLL is
         referenced relative to the working dir, so no deferred-context property expansion
         is needed. Runs elevated (Impersonate=no) which DllRegisterServer requires (HKLM/HKCR). -->
    <CustomAction Id="RegisterTsf" Directory="INSTALLFOLDER"
        ExeCommand="regsvr32.exe /s GenerativeIME.Tsf.dll"
        Execute="deferred" Impersonate="no" Return="check" />
    <CustomAction Id="UnregisterTsf" Directory="INSTALLFOLDER"
        ExeCommand="regsvr32.exe /s /u GenerativeIME.Tsf.dll"
        Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- Per-user TSF activation via Windows' official input.dll seed API.
         Runs deferred + Impersonate=yes so the *installing user's* HKCU gets
         seeded (Assemblies / Preload) and the ctfmon cache stays in sync -
         plain reg-writes in SeedHkcu.ps1 alone do not achieve that (per
         WDAC feedback round 4). -->
    <CustomAction Id="SeedTipForCurrentUser" FileRef="GenerativeImeSetupExe"
        ExeCommand="" Execute="deferred" Impersonate="yes" Return="ignore" />

    <!-- ==== 上書きアップデート用の custom actions ====
         Two modes, chosen by the FORCE_KILL public property:

           FORCE_KILL not set (default) — SAFE MODE.
             The taskkill CAs do NOT run. Windows Installer's built-in
             RestartManager detects file locks and either prompts the
             user (interactive install) or schedules a reboot to finish
             the replacement (silent install). Nothing gets terminated
             behind the user's back — a running DictManager, an active
             typing session, a chat window using the IME all survive.

           FORCE_KILL=1 — AGGRESSIVE MODE (installer/install.cmd sets this
             when the user picks "強引にアップデート").
             DictManager, GenerativeImeSetup and ctfmon are all killed
             before RemoveExistingProducts so file locks are released and
             the upgrade completes without a reboot. Cost: any unsaved
             work in DictManager is lost, and every app's IME state is
             re-initialized when ctfmon respawns.

         All three CAs use Directory=System64Folder so the working
         directory is stable even mid-wipe (INSTALLFOLDER may not exist
         yet). Return=ignore so a missing process (nothing to kill) isn't
         an install failure. -->

    <CustomAction Id="CloseDictMgr" Directory="System64Folder"
        ExeCommand="taskkill.exe /F /T /IM GenerativeIME.DictManager.exe"
        Execute="deferred" Impersonate="no" Return="ignore" />

    <CustomAction Id="CloseSetupExe" Directory="System64Folder"
        ExeCommand="taskkill.exe /F /T /IM GenerativeImeSetup.exe"
        Execute="deferred" Impersonate="no" Return="ignore" />

    <CustomAction Id="StopCtfmon" Directory="System64Folder"
        ExeCommand="taskkill.exe /F /IM ctfmon.exe"
        Execute="deferred" Impersonate="no" Return="ignore" />

    <!-- 「違うバージョンをインストールするとき真っさらにしてから」:
         after the old product's nested uninstall has removed the files
         it tracked, wipe INSTALLFOLDER clean so anything untracked (old
         .bak-* DLL backups, hand-copied dev artifacts, orphaned files
         from a previous install left behind by an interrupted uninstall)
         does not survive into the new install. RemoveExistingProducts is
         guaranteed to have finished before this by the sequence order.
         Same-version reinstall (AllowSameVersionUpgrades) also triggers
         WIX_UPGRADE_DETECTED, so a hotfix rebuild gets the same clean
         slate.

         Runs in BOTH safe and aggressive modes — it does not terminate
         any user process, it only deletes files the old MSI already
         "released" via RemoveExistingProducts. User-owned data lives
         OUTSIDE this folder (user dictionaries at %APPDATA%\GenerativeIME
         \dict, HKCU seed at Software\Microsoft\CTF\Assemblies) so
         wiping INSTALLFOLDER doesn't destroy anything the user configured. -->
    <CustomAction Id="WipeInstallFolder" Directory="System64Folder"
        ExeCommand="cmd.exe /c if exist &quot;[INSTALLFOLDER]&quot; ( rmdir /s /q &quot;[INSTALLFOLDER]&quot; )"
        Execute="deferred" Impersonate="no" Return="ignore" />

    <InstallExecuteSequence>
      <!-- Aggressive-only: kill anything holding file locks BEFORE the
           old product's nested uninstall runs. Gated on both
           FORCE_KILL=1 AND WIX_UPGRADE_DETECTED so a fresh install
           never fires them (nothing to kill) and a safe upgrade skips
           them (that's the whole point of safe mode). -->
      <Custom Action="CloseDictMgr"  Before="RemoveExistingProducts" Condition="WIX_UPGRADE_DETECTED AND FORCE_KILL = &quot;1&quot;" />
      <Custom Action="CloseSetupExe" After="CloseDictMgr"            Condition="WIX_UPGRADE_DETECTED AND FORCE_KILL = &quot;1&quot;" />
      <Custom Action="StopCtfmon"    After="CloseSetupExe"           Condition="WIX_UPGRADE_DETECTED AND FORCE_KILL = &quot;1&quot;" />

      <!-- After the old MSI is gone, wipe the folder. Safe in both modes.
           Then InstallFiles re-creates it from scratch. -->
      <Custom Action="WipeInstallFolder" After="RemoveExistingProducts" Condition="WIX_UPGRADE_DETECTED" />

      <Custom Action="RegisterTsf"          After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="SeedTipForCurrentUser" After="RegisterTsf" Condition="NOT REMOVE" />
      <Custom Action="UnregisterTsf"        Before="RemoveFiles" Condition="REMOVE" />
    </InstallExecuteSequence>

    <!-- FORCE_KILL declared here so the CLI/wrapper can override with
         msiexec /i ... FORCE_KILL=1. Secure=yes lets the property cross
         from client to server context (deferred CAs need it). -->
    <Property Id="FORCE_KILL" Secure="yes" />
  </Package>

  <Fragment>
    <ComponentGroup Id="PayloadFiles" Directory="INSTALLFOLDER">
      <!-- $(var.PayloadDir) is passed on the wix build command line
           (see build_msi.ps1) so the payload lives in a build-only
           directory rather than being hardcoded to a scratchpad UUID.
           Everything in payload/ is harvested; the launcher exe is
           declared explicitly below so it has a stable File Id/KeyPath
           the CustomAction can reference via FileRef. -->
      <Files Include="$(var.PayloadDir)\**">
        <Exclude Files="$(var.PayloadDir)\GenerativeImeSetup.exe" />
      </Files>
      <Component Id="GenerativeImeSetupExeComp" Guid="{A1B2C3D4-E5F6-4789-ABCD-EF0123456789}">
        <File Id="GenerativeImeSetupExe"
              Source="$(var.PayloadDir)\GenerativeImeSetup.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="TsfActivationRegistry" Directory="INSTALLFOLDER">
      <!-- v0.1.8 had a KlidRegistration component here (HKLM Keyboard Layouts
           E0210411 with Layout Text=GenerativeIME + IME File pointing at
           GenerativeIME.Tsf.dll). It surfaced as a *second* "GenerativeIME"
           entry alongside the TSF Assembly - the Win+Space picker listed it
           twice for the same IME. Removed in v0.1.9; the TSF profile from
           register.cpp + Preload=04110411 seeded by SeedHkcu.ps1 is enough
           for CTF to activate the TIP on modern Windows 11. If we ever need
           legacy-IMM app fallback we can reintroduce the KLID with a
           different label, but the current tests all pass without it. -->

      <!-- Active Setup entry. Runs SeedHkcu.ps1 once per user at first logon
           to write HKCU\CTF\Assemblies + Preload, which is what actually
           makes the TIP activatable for that user. Version bumped to 1,0,4
           in v0.1.9 so the seed re-runs on upgrade (the script itself now
           targets 04110411 instead of E0210411 and no longer writes
           Substitutes). -->
      <Component Id="ActiveSetupSeed" Guid="{5F3E9A21-4C8B-4D2E-9F1A-7B6C5D4E3F20}">
        <RegistryKey Root="HKLM" Key="Software\Microsoft\Active Setup\Installed Components\{5F3E9A21-4C8B-4D2E-9F1A-7B6C5D4E3F20}">
          <RegistryValue Type="string" Value="GenerativeIME per-user TSF seed" KeyPath="yes" />
          <RegistryValue Type="string" Name="Version" Value="1,0,4" />
          <RegistryValue Type="string" Name="StubPath"
                         Value="powershell.exe -ExecutionPolicy Bypass -WindowStyle Hidden -NonInteractive -File &quot;[INSTALLFOLDER]SeedHkcu.ps1&quot;" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
