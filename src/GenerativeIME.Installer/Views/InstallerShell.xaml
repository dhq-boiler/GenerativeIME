<Window x:Class="GenerativeIME.Installer.Views.InstallerShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GenerativeIME セットアップ"
        Icon="pack://application:,,,/app.ico"
        Height="520" Width="720"
        MinHeight="480" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource AppBg}"
        FontFamily="{StaticResource UiFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ContentControl Grid.Row="0" Content="{Binding CurrentPage}" Margin="0" />
        <Border Grid.Row="1" Background="{StaticResource Surface}" Padding="14,10"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding FooterText}" HorizontalAlignment="Right"
                       Foreground="{StaticResource Muted}" FontSize="11" />
        </Border>
    </Grid>
</Window>