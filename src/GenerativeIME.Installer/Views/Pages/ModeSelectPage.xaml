<UserControl x:Class="GenerativeIME.Installer.Views.Pages.ModeSelectPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource UiFont}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="36,32,36,0">
      <TextBlock Style="{StaticResource TitleText}" Text="アップデート方法"/>
      <TextBlock Style="{StaticResource SubtitleText}" Margin="0,6,0,20"
                 Text="既にインストール済みの GenerativeIME があります。上書き方法を選んでください。"/>

      <RadioButton Style="{StaticResource ChoiceTile}" IsChecked="{Binding IsSafeSelected}"
                   GroupName="Mode">
        <StackPanel>
          <TextBlock FontWeight="Bold" FontSize="14" Text="安全にアップデート  (推奨)"/>
          <TextBlock Style="{StaticResource SubtitleText}" Margin="0,6,0,0"
                     Text="実行中のアプリは終了させません。DLL がロック中の場合は、そのアプリ名を表示してインストールを中止します。"/>
          <TextBlock Style="{StaticResource SubtitleText}" Margin="0,4,0,0"
                     Text="他のアプリの作業を止めたくない場合はこちら。"/>
          <TextBlock FontWeight="Bold" FontSize="13" Margin="0,8,0,0"
                     Foreground="{StaticResource Danger}"
                     Text="⚠ 再起動が必要になります"/>
        </StackPanel>
      </RadioButton>

      <RadioButton Style="{StaticResource ChoiceTile}" IsChecked="{Binding IsAggressiveSelected}"
                   GroupName="Mode">
        <StackPanel>
          <TextBlock FontWeight="Bold" FontSize="14" Text="強引にアップデート  (再起動なし)"/>
          <TextBlock Style="{StaticResource SubtitleText}" Margin="0,6,0,0"
                     Text="DictManager と ctfmon を強制終了してから DLL を差し替えます。再起動不要でアップデートが完了します。"/>
          <TextBlock Style="{StaticResource SubtitleText}" Margin="0,4,0,0" Foreground="{StaticResource Danger}"
                     Text="⚠ DictManager の未保存作業は失われます。他のアプリの IME 状態も一瞬リセットされます。"/>
        </StackPanel>
      </RadioButton>
    </StackPanel>

    <Border Grid.Row="1" Background="{StaticResource Surface}"
            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,14">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Style="{StaticResource GhostButton}" Content="戻る" Command="{Binding BackCommand}" Margin="0,0,10,0"/>
        <Button Style="{StaticResource AccentButton}" Content="次へ" Command="{Binding NextCommand}"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
