<UserControl x:Class="GenerativeIME.Installer.Views.Pages.UninstallConfirmationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource UiFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="36,32,36,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Width="72" Height="72" VerticalAlignment="Top"
                   Source="pack://application:,,,/app-256.png"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <StackPanel Grid.Column="2">
                <TextBlock Style="{StaticResource TitleText}" Text="GenerativeIME をアンインストール" />
                <TextBlock Style="{StaticResource SubtitleText}" Margin="0,10,0,0">
                    <Run Text="バージョン: " />
                    <Run Text="{Binding InstalledVersion}" />
                </TextBlock>
                <TextBlock Style="{StaticResource SubtitleText}" Margin="0,2,0,20">
                    <Run Text="インストール先: " />
                    <Run Text="{Binding InstallLocation}" />
                </TextBlock>

                <TextBlock Style="{StaticResource SubtitleText}"
                           Text="以下を実行します:" />
                <TextBlock Style="{StaticResource SubtitleText}" Margin="12,4,0,2"
                           Text="  • 実行中の DictManager / ctfmon を終了" />
                <TextBlock Style="{StaticResource SubtitleText}" Margin="12,2,0,2"
                           Text="  • TSF テキストサービスの登録解除" />
                <TextBlock Style="{StaticResource SubtitleText}" Margin="12,2,0,2"
                           Text="  • インストール先フォルダの削除" />
                <TextBlock Style="{StaticResource SubtitleText}" Margin="12,2,0,2"
                           Text="  • アプリと機能エントリの削除" />
                <TextBlock Style="{StaticResource SubtitleText}" Margin="0,12,0,0"
                           Text="ユーザー辞書 (%APPDATA%\GenerativeIME\dict) は保持されます。" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource GhostButton}" Content="キャンセル" Command="{Binding CancelCommand}"
                        Margin="0,0,10,0" />
                <Button Style="{StaticResource AccentButton}" Content="アンインストール" Command="{Binding UninstallCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>