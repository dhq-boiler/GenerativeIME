<UserControl x:Class="GenerativeIME.Installer.Views.Pages.UninstallDonePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource UiFont}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="60,40">
      <TextBlock Style="{StaticResource TitleText}" Text="{Binding Title}"/>
      <TextBlock Style="{StaticResource SubtitleText}" Margin="0,10,0,0" Text="{Binding Detail}"/>
    </StackPanel>

    <Border Grid.Row="1" Background="{StaticResource Surface}"
            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="20,14">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Style="{StaticResource AccentButton}" Content="閉じる" Command="{Binding CloseCommand}"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
