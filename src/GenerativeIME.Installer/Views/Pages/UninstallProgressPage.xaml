<UserControl x:Class="GenerativeIME.Installer.Views.Pages.UninstallProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource UiFont}"
             Loaded="OnLoaded">
  <Grid>
    <StackPanel VerticalAlignment="Center" Margin="60,40">
      <TextBlock Style="{StaticResource TitleText}" Text="アンインストール中"/>
      <TextBlock Style="{StaticResource SubtitleText}" Margin="0,10,0,30" Text="{Binding StatusText}"/>
      <ProgressBar Height="10" Maximum="1.0" Value="{Binding ProgressValue}"
                   Background="{StaticResource SurfaceAlt}"
                   BorderBrush="{StaticResource Border}"
                   Foreground="{StaticResource Accent}"/>
    </StackPanel>
  </Grid>
</UserControl>
